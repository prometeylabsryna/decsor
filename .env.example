DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# База даних (локально — PostgreSQL)
DB_ENGINE=postgresql
DB_NAME=ltm_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Або один рядок (production):
# DATABASE_URL=mysql://user:password@localhost:3306/dbname

# Опційно: таймаут завантаження RSS (секунди)
MARKET_NEWS_FETCH_TIMEOUT=30

# Автоімпорт новин ринку (локально)
# macOS:  bash scripts/setup_market_news_cron.sh install-launchd
# Linux:  bash scripts/setup_market_news_cron.sh install
# Разово: bash scripts/setup_market_news_cron.sh run-now
MARKET_NEWS_CRON_SCHEDULE=0 */6 * * *
MARKET_NEWS_LOG_DIR=logs
DJANGO_SETTINGS_MODULE=config.settings.dev
# PYTHON_BIN=.venv/bin/python

# ─── Production FREEhost.UA ───────────────────────────────────────────────
# DJANGO_SETTINGS_MODULE=config.settings.production
# DEBUG=False
# DEPLOY_DOMAIN=yourdomain.com
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
#
# Shared hosting FREEhost (MySQL, тариф «Вигідний»+):
# DB_ENGINE=mysql
# DB_NAME=hosting_db_name
# DB_USER=hosting_db_user
# DB_PASSWORD=hosting_db_password
# DB_HOST=localhost
# DB_PORT=3306
#
# VPS / тариф «Максимум»+ (PostgreSQL):
# DB_ENGINE=postgresql
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
#
# Cron wget (панель FREEhost → Планувальник → метод wget):
# CRON_SECRET_TOKEN=generate-long-random-string
#
# Деплой shared FREEhost:
# bash scripts/deploy_freehost.sh install
#
# ─── VPS led-leader.com.ua (178.20.157.42) ────────────────────────────────
# Див. deploy/vps/env.production.example
# bash deploy/vps/bootstrap.sh
# bash scripts/deploy_vps.sh install
# certbot --nginx -d led-leader.com.ua -d www.led-leader.com.ua
