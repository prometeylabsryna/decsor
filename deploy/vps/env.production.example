# Production — VPS 178.20.157.42 · led-leader.com.ua
# На сервері: cp deploy/vps/env.production.example /var/www/itmcopy/.env

DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=False
SECRET_KEY=CHANGE_ME_GENERATE_WITH_python3_-c_import_secrets_print_secrets_token_urlsafe_50

DEPLOY_DOMAIN=led-leader.com.ua
ALLOWED_HOSTS=led-leader.com.ua,www.led-leader.com.ua,178.20.157.42,localhost,127.0.0.1

# До certbot (HTTP):
CSRF_TRUSTED_ORIGINS=http://led-leader.com.ua,http://www.led-leader.com.ua,http://178.20.157.42

# Після certbot замінити на:
# CSRF_TRUSTED_ORIGINS=https://led-leader.com.ua,https://www.led-leader.com.ua
# SECURE_SSL_REDIRECT=True

SECURE_SSL_REDIRECT=False
NGINX_SERVE_STATIC=True

# PostgreSQL (створюється bootstrap.sh)
DB_ENGINE=postgresql
POSTGRES_DB=itmcopy
POSTGRES_USER=itmcopy
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://itmcopy:CHANGE_ME_STRONG_DB_PASSWORD@localhost:5432/itmcopy

# Gunicorn
GUNICORN_BIND=127.0.0.1:8001
GUNICORN_WORKERS=3

# Автоімпорт новин (systemd timer + wget fallback)
MARKET_NEWS_CRON_SCHEDULE=0 */6 * * *
MARKET_NEWS_LOG_DIR=/var/www/itmcopy/logs
CRON_SECRET_TOKEN=CHANGE_ME_CRON_TOKEN

LOG_LEVEL=INFO
