[Unit]
Description=itmCopy Django (Gunicorn)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/var/www/itmcopy
EnvironmentFile=/var/www/itmcopy/.env
Environment=DJANGO_SETTINGS_MODULE=config.settings.production
ExecStart=/var/www/itmcopy/.venv/bin/gunicorn -c deploy/gunicorn/gunicorn.conf.py
ExecReload=/bin/kill -s HUP $MAINPID
Restart=on-failure
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
