# Приклад cron для імпорту новин ринку (liga.net/telecom, itc.ua)
#
# Локально (macOS/Linux):
#   bash scripts/setup_market_news_cron.sh install-launchd   # macOS
#   bash scripts/setup_market_news_cron.sh install           # Linux
#
# FREEhost.UA (панель → Планувальник CRON):
#   bash scripts/setup_market_news_cron.sh show-freehost
#   bash scripts/deploy_freehost.sh cron-info
#
# Розклад: кожні 6 годин (00:00, 06:00, 12:00, 18:00 за часом сервера)
# Змінити розклад: MARKET_NEWS_CRON_SCHEDULE у .env

0 */6 * * * /bin/bash /ABS/PATH/TO/itmCopy/scripts/fetch_market_news.sh
